---
import { company } from '../config/company';
---
<div class="bg-[#081b34] text-white/80 text-xs md:text-sm">
  <div class="max-w-7xl mx-auto px-6 py-2 flex flex-wrap items-center justify-between gap-2">
    <div class="flex items-center gap-5">
      <a href={company.phoneHref} class="hover:text-accent transition-colors">{company.phone}</a>
      <a href={`mailto:${company.email}`} class="hidden sm:inline hover:text-accent transition-colors">{company.email}</a>
    </div>
    <div class="flex items-center gap-4">
      <span class="hidden md:inline">Serving {company.serviceArea}</span>
      <div class="flex items-center gap-3">
        <a href={company.social.facebook} aria-label="Facebook" class="hover:text-accent transition-colors">FB</a>
        <a href={company.social.instagram} aria-label="Instagram" class="hover:text-accent transition-colors">IG</a>
        <a href={company.social.google} aria-label="Google Reviews" class="hover:text-accent transition-colors">G</a>
      </div>
    </div>
  </div>
</div>
