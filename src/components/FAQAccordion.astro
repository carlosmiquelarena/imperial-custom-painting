---
import ZigzagDivider from './ZigzagDivider.astro';
import { faqs } from '../config/faq';
---
<div>
  <ZigzagDivider color="var(--color-ink)" />
  <section class="bg-ink text-white py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-6">
      <p class="uppercase tracking-widest text-xs font-bold text-accent mb-2 text-center">
        Our Frequently Asked Questions
      </p>
      <h2 class="font-heading text-2xl md:text-3xl font-bold text-center mb-2">
        Frequently Asked Questions
      </h2>
      <div class="w-14 h-1 bg-accent mx-auto mb-12 rounded-full"></div>

      <div class="space-y-3">
        {faqs.map((item) => (
          <details class="group bg-white/5 rounded-lg border border-white/10 px-6 open:bg-white/10">
            <summary class="flex items-center justify-between gap-4 py-4 cursor-pointer font-medium list-none">
              {item.q}
              <svg width="14" height="14" viewBox="0 0 14 14" class="shrink-0 text-accent transition-transform group-open:rotate-45">
                <path d="M7 1v12M1 7h12" stroke="currentColor" stroke-width="1.5" fill="none"/>
              </svg>
            </summary>
            <p class="text-white/70 pb-5 leading-relaxed text-sm">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
  <ZigzagDivider color="var(--color-ink)" flip />
</div>
