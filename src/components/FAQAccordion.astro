---
import { faqs } from '../config/faq';
import TriangleTopDivider from './TriangleTopDivider.astro';
---

<section
  class="relative overflow-visible bg-cover bg-center py-16 md:py-20"
  style="background-image:url('/images/faq-bg.webp');"
>

  <!-- Divider -->
  <div class="absolute top-0 left-0 w-full -translate-y-full z-30">
    <TriangleTopDivider color="#6BD0DF" />
  </div>

  <!-- Overlay -->
  <div
    class="absolute inset-0"
    style="background-color:rgba(11,37,69,.95);"
  ></div>

  <!-- Content -->
  <div class="relative max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-14 items-start">

    <div class="text-white">

      <p class="uppercase tracking-widest text-xs font-bold text-white/70 mb-2">
        Our Frequently Asked Questions
      </p>

      <h2 class="font-heading text-3xl md:text-4xl font-bold mb-5">
        Frequently Asked Questions
      </h2>

      <div class="w-14 h-1 bg-accent mb-6 rounded-full"></div>

      <p class="text-white/80 leading-relaxed">
        Have a question? See our frequently asked questions &amp; answers.
        If you have any specific questions about your project, get in touch
        and we'll answer anything you need.
      </p>

    </div>

    <div class="divide-y divide-white/15">

      {faqs.map((item, i) => (

        <details class="group py-4" open={i === 0}>

          <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">

            <span class="font-heading font-bold text-sm text-white group-open:text-accent transition-colors">
              {item.q}
            </span>

            <svg
              width="14"
              height="14"
              viewBox="0 0 14 14"
              class="shrink-0 text-white transition-transform group-open:rotate-180 group-open:text-accent"
            >
              <path
                d="M2 4l5 5 5-5"
                stroke="currentColor"
                stroke-width="1.8"
                fill="none"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>

          </summary>

          <p class="pt-3 pr-6 text-sm leading-relaxed text-white/75">
            {item.a}
          </p>

        </details>

      ))}

    </div>

  </div>

</section>