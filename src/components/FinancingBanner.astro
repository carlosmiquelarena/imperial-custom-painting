---
// Optional block — omit from a client's index.astro if they don't offer financing.
---
<section class="py-16 bg-cream">
  <div class="max-w-5xl mx-auto px-6 bg-white rounded-2xl border border-ink/5 shadow-sm p-10 grid md:grid-cols-3 gap-8 items-center">
    <div class="md:col-span-2">
      <p class="text-sm font-semibold text-primary uppercase tracking-wide mb-2">Financing Available</p>
      <h3 class="font-heading text-2xl font-semibold text-ink mb-3">
        Split your project into monthly payments
      </h3>
      <p class="text-ink/70">
        Through our financing partner, get approved online in minutes and start your
        project without paying the full cost upfront.
      </p>
    </div>
    <a
      href="/financing"
      class="inline-flex items-center justify-center border border-primary text-primary px-6 py-3 rounded-md font-medium hover:bg-primary hover:text-white transition-colors"
    >
      Check Your Rate
    </a>
  </div>
</section>
