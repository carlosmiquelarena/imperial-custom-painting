---
import { services } from '../config/services';
---

<section class="py-16 md:py-20 bg-white">
  <div class="max-w-7xl mx-auto px-6">

    <div class="text-center max-w-xl mx-auto mb-12">
      <p class="uppercase tracking-widest text-sm font-bold text-accent mb-2">
        Our Services
      </p>

      <h2 class="font-heading text-2xl md:text-3xl font-bold text-ink mb-3">
        Painting Services In San Luis Obispo County and Surrounding Areas
      </h2>

      <div class="w-14 h-1 bg-accent mx-auto rounded-full"></div>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">

      {services.map((s, i) => {
        const bg = i === 0 ? '#6BD0DF' : '#0b2545';
        const imgSrc = `/images/services/${s.slug}.webp`;

        return (
          <a
            href={`/services/${s.slug}`}
            class="block overflow-hidden rounded-2xl shadow-lg transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl"
            style={{ backgroundColor: bg }}
          >
            <div class="aspect-[4/3] overflow-hidden">
              <img
                src={imgSrc}
                alt={s.name}
                class="h-full w-full object-cover transition-transform duration-500 hover:scale-105"
                onerror="this.parentElement.style.display='none'"
              />
            </div>

            <div class="p-6 text-center text-white">

              <h3 class="font-heading mb-3 text-xl font-bold underline decoration-2 underline-offset-4">
                {s.name}
              </h3>

              <p class="text-sm leading-relaxed text-white/85">
                {s.blurb}
              </p>

            </div>

          </a>
        );
      })}

    </div>

  </div>
  
</section>