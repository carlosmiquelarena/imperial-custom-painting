---
import { services } from '../config/services';
---
<section class="bg-white py-16 md:py-20">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center max-w-xl mx-auto mb-12">
      <p class="uppercase tracking-widest text-sm font-bold text-accent mb-2">Our Services</p>
      <h2 class="font-heading text-2xl md:text-3xl font-bold text-ink mb-3">
        Every surface, one crew
      </h2>
      <div class="w-14 h-1 bg-accent mx-auto rounded-full"></div>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((s) => (
        <a
          href={`/services/${s.slug}`}
          class="group block bg-white rounded-lg p-7 border border-ink/10 hover:border-accent hover:shadow-lg transition-all"
        >
          <div class="w-11 h-11 rounded-lg bg-ink/5 flex items-center justify-center mb-5 group-hover:bg-accent transition-colors">
            <span class="w-2.5 h-2.5 rounded-full bg-accent group-hover:bg-ink transition-colors"></span>
          </div>
          <h3 class="font-heading text-lg font-bold text-ink mb-2">{s.name}</h3>
          <p class="text-sm text-ink/60 leading-relaxed">{s.blurb}</p>
        </a>
      ))}
    </div>
  </div>
</section>
