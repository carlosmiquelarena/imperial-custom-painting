---
import { company } from '../config/company';
import { services } from '../config/services';
import { cities } from '../config/cities';
import { Facebook, Instagram, Star } from 'lucide-astro';
---

<header class="absolute top-0 left-0 w-full z-50 mt-5">
  <div class="w-[90%] max-w-7xl mx-auto py-4 pt-10 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center">
      <img
        src={company.logo.src}
        alt={company.logo.alt}
        width={company.logo.width}
        height={company.logo.height}
        class="h-14 w-auto object-contain"
      />
    </a>


    <!-- Navigation -->
    <nav class="hidden lg:flex items-center gap-8 font-semibold text-sm text-white uppercase tracking-wide">

      <a href="/" class="py-2 hover:text-accent transition-colors">
        Homepage
      </a>


      <!-- Services Dropdown -->
      <div class="group relative">

        <button class="flex items-center gap-1 py-2 hover:text-accent transition-colors">
          SERVICES

          <svg width="10" height="6" viewBox="0 0 10 6" class="mt-0.5">
            <path
              d="M1 1l4 4 4-4"
              stroke="currentColor"
              stroke-width="1.5"
              fill="none"
            />
          </svg>

        </button>


        <div class="absolute left-0 top-full hidden group-hover:grid grid-cols-2 gap-x-6 gap-y-1 bg-white shadow-xl rounded-lg p-5 w-96 border border-black/5 normal-case">

          {services.map((s) => (
            <a
              href={`/services/${s.slug}`}
              class="py-1.5 text-sm text-ink hover:text-primary transition-colors"
            >
              {s.name}
            </a>
          ))}

        </div>

      </div>



      <a href="/about" class="py-2 hover:text-accent transition-colors">
        ABOUT US
      </a>



      <!-- Areas Dropdown -->
      <div class="group relative">

        <button class="flex items-center gap-1 py-2 hover:text-accent transition-colors">

          AREAS WE SERVE

          <svg width="10" height="6" viewBox="0 0 10 6" class="mt-0.5">
            <path
              d="M1 1l4 4 4-4"
              stroke="currentColor"
              stroke-width="1.5"
              fill="none"
            />
          </svg>

        </button>


        <div class="absolute left-0 top-full hidden group-hover:grid grid-cols-2 gap-x-6 gap-y-1 bg-white shadow-xl rounded-lg p-5 w-80 border border-black/5 max-h-96 overflow-y-auto normal-case">

          {cities.map((c) => (
            <a
              href={`/${c.slug}`}
              class="py-1.5 text-sm text-ink hover:text-primary transition-colors"
            >
              {c.name}
            </a>
          ))}

        </div>

      </div>



      <a href="/contact" class="py-2 hover:text-accent transition-colors">
        CONTACT US
      </a>

    </nav>



    <!-- CTA -->
    <a
      href={company.cta.href}
      class="hidden sm:inline-flex items-center px-5 py-2.5 rounded-md font-bold text-sm uppercase text-ink hover:brightness-95 transition"
      style="background-color:#6BD0DF;"
    >
      {company.cta.label}
    </a>


  </div>
</header>