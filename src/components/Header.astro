---
import { company } from '../config/company';
import { services } from '../config/services';
import { cities } from '../config/cities';
---
<header class="bg-ink sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="font-heading text-xl font-bold text-white">
      {company.name}
    </a>

    <nav class="hidden lg:flex items-center gap-8 font-semibold text-sm text-white/90 uppercase tracking-wide">
      <a href="/" class="py-2 hover:text-accent transition-colors">Homepage</a>
      <div class="group relative">
        <button class="flex items-center gap-1 py-2 hover:text-accent transition-colors">
          Services
          <svg width="10" height="6" viewBox="0 0 10 6" class="mt-0.5"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>
        </button>
        <div class="absolute left-0 top-full hidden group-hover:grid grid-cols-2 gap-x-6 gap-y-1 bg-white shadow-xl rounded-lg p-5 w-96 border border-ink/5 normal-case">
          {services.map((s) => (
            <a href={`/services/${s.slug}`} class="py-1.5 text-sm text-ink hover:text-primary transition-colors">{s.name}</a>
          ))}
        </div>
      </div>

      <a href="/about" class="py-2 hover:text-accent transition-colors">About Us</a>

      <div class="group relative">
        <button class="flex items-center gap-1 py-2 hover:text-accent transition-colors">
          Areas We Serve
          <svg width="10" height="6" viewBox="0 0 10 6" class="mt-0.5"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>
        </button>
        <div class="absolute left-0 top-full hidden group-hover:grid grid-cols-2 gap-x-6 gap-y-1 bg-white shadow-xl rounded-lg p-5 w-80 border border-ink/5 max-h-96 overflow-y-auto normal-case">
          {cities.map((c) => (
            <a href={`/${c.slug}`} class="py-1.5 text-sm text-ink hover:text-primary transition-colors">{c.name}</a>
          ))}
        </div>
      </div>

      <a href="/contact" class="py-2 hover:text-accent transition-colors">Contact Us</a>
    </nav>

    <a
      href={company.cta.href}
      class="hidden sm:inline-flex items-center bg-accent text-ink px-5 py-2.5 rounded-md font-bold text-sm uppercase hover:brightness-95 transition"
    >
      {company.cta.label}
    </a>
  </div>
</header>
