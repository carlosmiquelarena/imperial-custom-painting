---
import { company } from '../config/company';

const reasons = [
  { title: 'Fast & Cost-Effective Transformation', desc: 'Interior painting is one of the easiest and most affordable ways to improve your home without the stress, cost, or downtime of a full renovation.' },
  { title: 'Protect and Extend Wall Life', desc: 'A professional interior paint job does more than improve a space, it helps protect your walls from moisture, stains, and everyday wear.' },
  { title: 'Boost Home Value & Buyer Appeal', desc: 'Outdated interiors can reduce your home\u2019s appeal to potential buyers. Fresh paint helps modernize your space.' },
  { title: 'Bring Your Vision to Life', desc: 'Styles and trends evolve, and your space should too. Interior painting is a simple way to update the look and feel of your home or business.' },
];
---
<section class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-6 text-center">
    <p class="uppercase tracking-widest text-sm font-bold text-accent mb-2">Why Choose Us?</p>
    <h2 class="font-heading text-2xl md:text-3xl font-bold text-ink mb-3">
      Why Choose Us For Painting Services?
    </h2>
    <div class="w-14 h-1 bg-accent mx-auto mb-14 rounded-full"></div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      {reasons.map((r) => (
        <div>
          <div class="w-14 h-14 mx-auto rounded-full bg-accent/10 flex items-center justify-center mb-4">
            <span class="w-3 h-3 rounded-full bg-accent"></span>
          </div>
          <h3 class="font-heading font-bold text-sm text-ink mb-2 uppercase">{r.title}</h3>
          <p class="text-xs text-ink/60 leading-relaxed">{r.desc}</p>
        </div>
      ))}
    </div>

    <p class="text-ink/70 max-w-2xl mx-auto mb-6 text-sm">
      Your home experience daily use, which is why we only use quality paints,
      tools, and materials. This ensures a flawless finish that lasts longer and looks amazing.
    </p>
    <a href={company.cta.href} class="inline-flex items-center bg-ink text-white px-7 py-3.5 rounded-md font-bold hover:bg-primary transition-colors">
      {company.cta.label}
    </a>
  </div>
</section>
