---
import { PaintRoller } from 'lucide-astro';
import { company } from '../config/company';

const reasons = [
  { title: 'Fast & Cost-Effective Transformation', desc: 'Interior painting is one of the easiest and most affordable ways to transform your home without the stress, cost, or downtime of a full renovation. While remodeling can take weeks, a fresh coat of paint can completely refresh your space in just a few days.' },
  { title: 'Protect and Extend Wall Life', desc: 'A professional interior paint job does more than improve appearance — it helps protect your walls from moisture, stains, and everyday wear. Using high-quality materials ensures long-lasting durability and keeps your home looking clean and well-maintained.' },
  { title: "Boost Home Value & Buyer Appeal", desc: "Outdated interiors can reduce your home's attractiveness to potential buyers. A fresh, neutral paint job instantly modernizes your space, making it more appealing and helping turn your property into a move-in-ready home." },
  { title: 'Bring Your Vision to Life', desc: 'Styles and trends evolve — and your space should too. Interior painting is a simple way to update the look and feel of your home or business. We help you create a space that reflects your personality and feels fresh, modern, and inviting.' },
];

const lastReason = {
  title: 'Premium Paints & Professional Materials',
  desc: 'Your home experiences daily wear, which is why we use only top-quality paints, tools, and materials. This ensures a flawless finish that lasts longer and stands up to everyday use.',
};
---
<section class="py-20 bg-white">
  <div class="max-w-4xl mx-auto px-6 text-center">
    <p class="uppercase tracking-widest text-sm font-bold text-accent mb-2">Why Choose Us?</p>
    <h2 class="font-heading text-2xl md:text-3xl font-bold text-ink mb-4 leading-snug">
      Why Choose {company.name} For Painting Services?
    </h2>
    <div class="w-16 h-0.5 bg-accent mx-auto mb-16"></div>

    <div class="grid sm:grid-cols-2 gap-x-12 gap-y-14 mb-14 text-left sm:text-center">
      {reasons.map((r) => (
        <div>
          <PaintRoller color="#6BD0DF" size={34} class="mx-auto mb-4" />
          <h3 class="font-heading font-bold text-sm text-ink mb-3 uppercase tracking-wide">{r.title}</h3>
          <p class="text-sm text-ink/60 leading-relaxed">{r.desc}</p>
        </div>
      ))}
    </div>

    <div class="max-w-md mx-auto mb-14">
      <PaintRoller color="#6BD0DF" size={34} class="mx-auto mb-4" />
      <h3 class="font-heading font-bold text-sm text-ink mb-3 uppercase tracking-wide">{lastReason.title}</h3>
      <p class="text-sm text-ink/60 leading-relaxed">{lastReason.desc}</p>
    </div>

       
          <a
  href={company.cta.href}
  class="inline-flex items-center rounded-md bg-accent px-7 py-3.5 text-sm font-bold uppercase tracking-wide text-ink transition-all duration-300 hover:-translate-y-0.5 hover:brightness-95"
>
  Get Free Estimate
</a>
  </div>
</section>
